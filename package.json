{
  "name": "petcare-platform",
  "version": "0.1.0",
  "private": true,
  "description": "The PetCare multi-tenant platform workspace.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=11.0.0 <12"
  },
  "scripts": {
    "build": "pnpm --filter @petcare/web build",
    "dev": "pnpm --filter @petcare/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --recursive --if-present lint",
    "test": "pnpm --recursive --if-present test",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.6.2",
    "supabase": "^2.109.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
