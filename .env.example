# Public application URL. Do not put secrets in NEXT_PUBLIC variables.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Create these values with `supabase start` for local development.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key

# Optional browser key for Google Places address autocomplete during business setup.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-browser-restricted-google-maps-key

# Server-only values. Never expose this key to the browser.
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Stripe webhook endpoint secret. Use the Stripe CLI secret locally and the
# Dashboard/Workbench endpoint secret in each deployed environment.
STRIPE_WEBHOOK_SECRET=whsec_replace-with-environment-specific-secret
STRIPE_SECRET_KEY=sk_test_replace-with-server-only-platform-key

# Server-only transactional email delivery. CRON_SECRET protects the worker endpoint.
RESEND_API_KEY=re_replace-with-server-only-key
TRANSACTIONAL_EMAIL_FROM=PetCare <notifications@example.com>
CRON_SECRET=replace-with-long-random-secret
